{
    "$schema": "https://frontmatter.codes/frontmatter.schema.json",
    "frontMatter.taxonomy.contentTypes": [
        {
            "name": "default",
            "pageBundle": true,
            "previewPath": null,
            "filePrefix": null,
            "fields": [
                {
                    "title": "Title",
                    "name": "title",
                    "type": "string"
                },
                {
                    "title": "Slug",
                    "name": "slug",
                    "type": "slug",
                    "editable": false,
                    "default": "{{slug}}"
                },
                {
                    "title": "Publishing date",
                    "name": "date",
                    "type": "datetime",
                    "default": "{{now}}",
                    "isPublishDate": true
                },
                {
                    "title": "Meta description (SEO)",
                    "name": "description",
                    "type": "string",
                    "description": "Plain-text summary for search & social (~150–160 characters)."
                },
                {
                    "title": "Post language",
                    "name": "post_lang",
                    "type": "string",
                    "default": "en",
                    "description": "ISO 639-1 code: en or fr (hreflang + html lang)."
                },
                {
                    "title": "Content preview",
                    "name": "image",
                    "type": "image",
                    "isPreviewImage": true,
                    "default": "featured.jpg"
                },
                {
                    "title": "Featured image alt text",
                    "name": "image_alt",
                    "type": "string",
                    "description": "Short accessible description; defaults to title if empty."
                },
                {
                    "title": "Canonical URL (optional)",
                    "name": "canonical",
                    "type": "string",
                    "description": "Override canonical if republished elsewhere."
                },
                {
                    "title": "Last modified (optional)",
                    "name": "lastmod",
                    "type": "datetime",
                    "description": "Override last modified; Git is used when unset."
                },
                {
                    "title": "Is in draft",
                    "name": "draft",
                    "type": "draft",
                    "default": false
                },
                {
                    "title": "Tags",
                    "name": "tags",
                    "type": "tags"
                },
                {
                    "title": "Categories",
                    "name": "categories",
                    "type": "categories"
                },
                {
                    "title": "aliases",
                    "name": "aliases",
                    "type": "list",
                    "default": [
                        "post/{{slug}}"
                    ],
                    "hidden": true
                }
            ]
        }
    ],
    "frontMatter.framework.id": "hugo",
    "frontMatter.content.publicFolder": "static",
    "frontMatter.preview.host": "http://localhost:1313",
    "frontMatter.content.pageFolders": [
        {
            "title": "This year posts",
            "path": "[[workspace]]/content/posts/{{year}}"
        },
        {
            "title": "Blog Posts",
            "path": "[[workspace]]/content/posts",
            "disableCreation": true
        }
    ],
    "frontMatter.framework.startCommand": "hugo serve"
}